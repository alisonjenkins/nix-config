# Custom nix-direnv-style .envrc that skips per-flake-input gcroot creation.
# Stock `use flake` calls `nix build --out-link` once per flake.lock input
# (107 of them in this repo) which dominates cold reload time. The dev
# shell's own derivation is still gcroot-protected via the profile symlink;
# only the eval-time flake input sources are unprotected, so a subsequent
# `nix-collect-garbage` may force re-fetching them on the next reload.

watch_file flake.nix flake.lock flake-modules/dev-shells.nix

layout_dir="$(direnv_layout_dir)"
profile="$layout_dir/devshell-profile"
profile_rc="$profile.rc"

needs_update=0
if [[ ! -e $profile || ! -e $profile_rc ]]; then
  needs_update=1
else
  for f in flake.nix flake.lock flake-modules/dev-shells.nix; do
    if [[ $f -nt $profile_rc ]]; then
      needs_update=1
      break
    fi
  done
fi

if [[ $needs_update -eq 1 ]]; then
  log_status "rebuilding dev shell profile"
  mkdir -p "$layout_dir"
  if rc_contents=$(nix --no-warn-dirty --accept-flake-config \
      --extra-experimental-features "nix-command flakes" \
      print-dev-env --profile "$profile" .); then
    printf '%s\n' "$rc_contents" > "$profile_rc"
  else
    log_error "nix print-dev-env failed"
    return 1
  fi
fi

[[ -e $profile_rc ]] && eval "$(<"$profile_rc")"
