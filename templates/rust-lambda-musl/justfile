lambda_name := "my-lambda"
region := "eu-west-1"
ecr_repo := "my-lambda"

# Build the Lambda binary with Nix
build:
    nix build

# Build the distroless Lambda container image
container:
    nix build .#container

# Run checks (clippy, fmt, tests, doc)
check:
    nix flake check

# Start the local Lambda emulator
watch:
    cargo lambda watch

# Invoke the local Lambda for testing
invoke payload='{"name": "world"}':
    cargo lambda invoke --data-ascii '{{ payload }}'

# Deploy using cargo-lambda (zip-based)
deploy-zip:
    cargo lambda build --release
    cargo lambda deploy

# Push container image to ECR
push: container
    #!/usr/bin/env bash
    set -euo pipefail
    ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
    REGISTRY="${ACCOUNT_ID}.dkr.ecr.{{ region }}.amazonaws.com"
    aws ecr get-login-password --region {{ region }} | docker login --username AWS --password-stdin "$REGISTRY"
    docker load < result
    docker tag {{ lambda_name }}:latest "$REGISTRY/{{ ecr_repo }}:latest"
    docker push "$REGISTRY/{{ ecr_repo }}:latest"
