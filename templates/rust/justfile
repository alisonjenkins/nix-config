# List available recipes
default:
    @just --list

# Build the binary with Nix
build:
    nix build

# Build the container image
container:
    nix build .#container

# Run checks (clippy, fmt, tests, doc)
check:
    nix flake check

# Run tests
test:
    cargo nextest run

# Run the application
run *args:
    cargo run -- {{args}}

# Format code
fmt:
    cargo fmt

# Run clippy lints
lint:
    cargo clippy --all-targets -- --deny warnings

# Watch for changes and rebuild
watch:
    cargo watch -x run
